{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://krax/contracts/runtime_artifacts/execution_manifest.schema.json",
  "title": "ExecutionManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "stage",
    "commands_run",
    "files_changed",
    "validation_outputs",
    "created_at"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "stage": { "const": "flash" },
    "commands_run": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "validation_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
