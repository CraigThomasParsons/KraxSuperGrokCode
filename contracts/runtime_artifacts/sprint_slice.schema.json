{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://krax/contracts/runtime_artifacts/sprint_slice.schema.json",
  "title": "SprintSlice",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "stage",
    "sprint_id",
    "task_ids",
    "created_at"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "stage": { "const": "mason" },
    "sprint_id": { "type": "string", "pattern": "^sprint_[0-9]{2}$" },
    "task_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
