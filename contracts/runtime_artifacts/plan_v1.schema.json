{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://krax/contracts/runtime_artifacts/plan_v1.schema.json",
  "title": "PlanV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "stage",
    "summary",
    "constraints",
    "acceptance_checks",
    "created_at"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "stage": { "const": "auralis" },
    "summary": { "type": "string", "minLength": 1 },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptance_checks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
