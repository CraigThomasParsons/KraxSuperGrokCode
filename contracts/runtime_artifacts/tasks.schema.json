{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://krax/contracts/runtime_artifacts/tasks.schema.json",
  "title": "Tasks",
  "type": "object",
  "additionalProperties": false,
  "required": ["job_id", "stage", "tasks", "created_at"],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "stage": { "enum": ["mason", "flash"] },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "owner", "done_criteria"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "enum": ["mason", "flash"] },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "done_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
