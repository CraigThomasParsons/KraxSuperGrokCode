{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://krax/contracts/runtime_artifacts/vera_evidence.schema.json",
  "title": "VeraEvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "stage",
    "bundle_id",
    "items",
    "created_at"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "stage": { "const": "vera" },
    "bundle_id": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "exists"],
        "properties": {
          "kind": { "type": "string", "enum": ["log", "artifact", "trace", "screenshot"] },
          "path": { "type": "string", "minLength": 1 },
          "exists": { "type": "boolean" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "note": { "type": "string" }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
